{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "out/main",
    "lib": ["ES2022"],
    "types": ["node"],
    "composite": true,
    "noEmit": true,
    "paths": {
      "@shared/*": ["src/shared/*"]
    }
  },
  "include": ["src/main/**/*.ts"],
  "references": [{ "path": "./tsconfig.shared.json" }]
}
