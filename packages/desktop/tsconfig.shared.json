{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src/shared",
    "outDir": "out/shared",
    "composite": true,
    "declaration": true,
    "tsBuildInfoFile": "out/shared/tsconfig.shared.tsbuildinfo",
    // DOM lib so global `URL` resolves. TS 6.0 dropped URL from the
    // ES2022 default; src/shared/url.ts uses it. Adding DOM here is
    // type-only — no runtime cost — and shared code sees URL the same
    // way the renderer does.
    "lib": ["ES2022", "DOM"]
  },
  "include": ["src/shared/**/*.ts"]
}
