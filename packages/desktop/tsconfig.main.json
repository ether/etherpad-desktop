{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "out/main",
    "lib": ["ES2022"],
    "types": ["node"],
    "composite": true,
    "noEmit": true,
    // baseUrl was deprecated in TS 6.0 and removed in 7.0. With
    // moduleResolution: "bundler" (set in tsconfig.base.json), `paths`
    // entries can be relative to the tsconfig directory directly —
    // no baseUrl needed.
    "paths": {
      "@shared/*": ["../shell/src/*"]
    }
  },
  "include": ["src/main/**/*.ts"],
  "references": [{ "path": "../shell/tsconfig.shell.json" }]
}
