{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "out/preload",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "composite": true,
    "noEmit": true,
    "paths": {
      "@shared/*": ["../shell/src/*"]
    }
  },
  "include": ["src/preload/**/*.ts"],
  "references": [{ "path": "../shell/tsconfig.shell.json" }]
}
