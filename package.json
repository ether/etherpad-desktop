{
  "name": "etherpad-desktop",
  "private": true,
  "version": "0.3.0",
  "description": "Native desktop client for Etherpad",
  "license": "Apache-2.0",
  "author": "Etherpad Foundation",
  "homepage": "https://etherpad.org/",
  "repository": "github:ether/etherpad-desktop",
  "main": "./out/main/index.cjs",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc -b --pretty",
    "lint": "eslint src tests",
    "format": "prettier --write src tests",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "node scripts/run-e2e.mjs",
    "package": "electron-vite build && electron-builder --linux --config build/electron-builder.yml",
    "package:win": "electron-vite build && electron-builder --win --config build/electron-builder.yml",
    "package:linux": "electron-vite build && electron-builder --linux --config build/electron-builder.yml",
    "package:mac": "electron-vite build && electron-builder --mac --config build/electron-builder.yml",
    "start": "electron-vite preview"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.8.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.0.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/tmp": "^0.2.6",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.5.0",
    "electron-builder": "^26.6.0",
    "electron-vite": "^5.0.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "playwright-core": "^1.59.1",
    "prettier": "^3.5.3",
    "tmp": "^0.2.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "//": "pnpm 9+ blocks postinstall scripts by default. Without these on the allowlist, electron's binary download postinstall is skipped and tests fail with 'Electron failed to install correctly'.",
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild"
    ]
  }
}
